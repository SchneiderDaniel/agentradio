{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "{{headline}}",
  "description": "{{description}}",
  "author": {
    "@type": "Person",
    "name": "{{author_name}}",
    "url": "{{author_url}}",
    "jobTitle": "{{author_title}}"
  },
  "publisher": {
    "@type": "Organization",
    "name": "{{org_name}}",
    "url": "{{org_url}}",
    "logo": {
      "@type": "ImageObject",
      "url": "{{logo_url}}"
    }
  },
  "datePublished": "{{date_published}}",
  "dateModified": "{{date_modified}}",
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "{{page_url}}"
  },
  "image": "{{featured_image_url}}"
}
